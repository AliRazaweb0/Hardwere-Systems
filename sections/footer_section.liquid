<!-- Font Awesome (Icons FIX) -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<!-- =========================
   FILTER SECTION (REDIRECT)
========================= -->
<div class="filter-section">
    <div class="filter-container">

        <a href="/collections/all" class="filter-btn active">All Systems</a>

        {% for collection in collections %}
            {% if collection.handle != 'all' and collection.products_count > 0 %}
                <a href="{{ collection.url }}" class="filter-btn">
                    {{ collection.title }}
                </a>
            {% endif %}
        {% endfor %}

    </div>

    <div class="section-header">
        <p class="section-subtitle">
            {{ collections.all.products_count }} Systems Available
        </p>
        <h1 class="section-title">Systems</h1>
    </div>
</div>

<!-- =========================
   PRODUCT CARDS
========================= -->
<div class="cards-container">
    {% for product in collections.all.products %}
        <div class="product-card">

            <div class="image-wrapper">
                <img src="{{ product.featured_image | img_url: '600x400' }}" 
                     alt="{{ product.title }}" class="card-image">

                <!-- Heart -->
                <div class="heart-icon-top" onclick="toggleHeart(this)">
                    <i class="fa-solid fa-heart"></i>
                </div>
            </div>

            <div class="card-content">
                <h3 class="card-title">{{ product.title }}</h3>

                <p class="card-description">
                    {{ product.description | strip_html | truncate: 80 }}
                </p>

                <a href="{{ product.url }}" class="view-link">VIEW SYSTEM</a>

                <button class="wishlist-btn" onclick="toggleWishlist(this)">
                    <i class="fa-solid fa-bookmark"></i>
                    <span>Wishlist</span>
                </button>
            </div>

        </div>
    {% endfor %}
</div>

<!-- =========================
   CSS
========================= -->
<style>

/* Layout */
.cards-container {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px; /* reduced gap */
    max-width: 1100px;
    margin: auto;
    padding: 0 10px;
}

.product-card {
    background: #fff;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 3px 10px rgba(0,0,0,0.08);
    transition: 0.3s;
}

.product-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.15);
}

/* Image */
.image-wrapper {
    position: relative;
    height: 200px;
}

.card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

/* Heart Icon */
.heart-icon-top {
    position: absolute;
    top: 10px;
    right: 10px;
    width: 34px;
    height: 34px;
    background: #fff;
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    cursor: pointer;
    z-index: 999;
}

.heart-icon-top i {
    color: #555;
}

.heart-icon-top.active {
    background: red;
}

.heart-icon-top.active i {
    color: #fff;
}

/* Content */
.card-content {
    padding: 15px;
    position: relative;
    padding-bottom: 60px;
}

.card-title {
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 8px;
}

.card-description {
    font-size: 13px;
    color: #666;
    margin-bottom: 10px;
}

/* View Button */
.view-link {
    display: inline-block;
    background: #000;
    color: #fff;
    padding: 7px 14px;
    font-size: 12px;
    text-decoration: none;
    border-radius: 4px;
}

.view-link:hover {
    background: #ff6b9d;
}

/* Wishlist */
.wishlist-btn {
    position: absolute;
    bottom: 10px;
    left: 15px;
    right: 15px;
    padding: 8px;
    border: 1px solid #ddd;
    background: #fff;
    cursor: pointer;
    font-size: 12px;
}

.wishlist-btn.active {
    background: red;
    color: #fff;
}

/* Filter */
.filter-container {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 20px;
}

.filter-btn {
    padding: 8px 16px;
    border: 1px solid #ddd;
    text-decoration: none;
    color: #333;
    border-radius: 20px;
    font-size: 12px;
}

.filter-btn:hover {
    background: black;
    color: #fff;
}

.filter-btn.active {
    background: black;
    color: #fff;
}

/* Responsive */
@media(max-width: 768px){
    .cards-container {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media(max-width: 480px){
    .cards-container {
        grid-template-columns: 1fr;
    }
}

</style>

<!-- =========================
   JS
========================= -->
<script>

function toggleHeart(el) {
    el.classList.toggle("active");
}

function toggleWishlist(btn) {
    btn.classList.toggle("active");
}

</script>