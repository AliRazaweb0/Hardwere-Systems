<!-- Cards Container -->
<div class="cards-container">
  {% for product in collections.all.products %}
    <div class="product-card">
        <div class="image-wrapper">
            <img src="{{ product.featured_image | img_url: '800x600' }}" 
                 alt="{{ product.title }}" class="card-image">
            
            <!-- Heart Icon Top Right -->
            <div class="heart-icon-top" onclick="toggleHeart(this)" title="Like">
                <i class="fas fa-heart"></i>
            </div>
        </div>
        
        <div class="card-content">
            <!-- Product Title -->
            <h3 class="card-title">{{ product.title }}</h3>

            <!-- Product Description -->
            <p class="card-description">{{ product.description | strip_html | truncate: 100 }}</p>

            <!-- View System Button -->
            <a href="{{ product.url }}" class="view-link">VIEW SYSTEM</a>
            
            <!-- Wishlist Button -->
            <button class="wishlist-btn" onclick="toggleWishlist(this)">
                <i class="fas fa-bookmark"></i>
                <span>Wishlist</span>
            </button>
        </div>
    </div>
  {% endfor %}
</div>

<style>
/* Ensure 3 cards per row layout */
.cards-container {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
}

.product-card {
    flex: 1 1 calc(33.333% - 16px); /* 3 cards per row */
    max-width: calc(33.333% - 16px);
    margin-bottom: 24px;
}

@media (max-width: 1024px) {
    .product-card {
        flex: 1 1 calc(50% - 12px); /* 2 cards per row on tablet */
        max-width: calc(50% - 12px);
    }
}

@media (max-width: 768px) {
    .product-card {
        flex: 1 1 100%; /* 1 card per row on mobile */
        max-width: 100%;
    }
}
</style>