    line-height: 1.5;
    margin-bottom: 15px;
    opacity: 0.9;
    max-width: 400px;
}

.explore-link {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: gap 0.3s;
}

.category-card:hover .explore-link {
    gap: 12px;
}

.explore-link i {
    font-size: 10px;
}

/* Responsive */
@media (max-width: 768px) {
    .categories-grid {
        grid-template-columns: 1fr;
        grid-template-rows: auto;
    }

    .category-card.large,
    .category-card.small {
        grid-column: span 1;
        height: 280px;
    }

    .card-overlay h3 {
