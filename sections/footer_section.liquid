<style>
/* ============================================
   TUMHARA CSS - CARDS STRUCTURE BILKUL SAME
   ============================================ */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
}

body {
    background-color: #f8f8f8;
    padding: 40px;
}

.container {
    max-width: 1200px;
    margin: 0 auto;
}

/* ============================================
   COLLECTION HEADER
   ============================================ */
.collection-header {
    padding: 40px 40px 0 40px;
    margin-bottom: 20px;
}

.collection-header .subtitle {
    font-size: 11px;
    letter-spacing: 3px;
    color: #888;
    margin-bottom: 8px;
    text-transform: uppercase;
}

.collection-header h1 {
    font-size: 30px;
    color: #222;
    font-weight: bold;
}

/* ============================================
   FIRST COLLECTION - FULL WIDTH
   ============================================ */
.first-collection {
    margin-bottom: 60px;
}

.first-collection-card {
    display: block;
    height: 450px;
    position: relative;
    border-radius: 10px;
    overflow: hidden;
    color: #fff;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    transition: transform 0.4s ease;
    text-decoration: none;
    margin-bottom: 40px;
}

.first-collection-card:hover {
    transform: scale(1.04);
}

.first-collection-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.4) 50%, transparent 100%);
    z-index: 1;
}

.first-collection-card .text {
    position: absolute;
    bottom: 25px;
    left: 25px;
    z-index: 2;
    max-width: 80%;
}

.first-collection-card .text h3 {
    font-size: 22px;
    font-weight: bold;
    margin-bottom: 8px;
}

.first-collection-card .text p {
    font-size: 14px;
    opacity: 0.9;
    margin-bottom: 10px;
}

.first-collection-card .text span {
    font-size: 13px;
    font-weight: bold;
    text-transform: uppercase;
}

/* ============================================
   PRODUCTS GRID - 3 PER ROW
   ============================================ */
.products-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
}

@media (max-width: 1024px) {
    .products-grid {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media (max-width: 768px) {
    .products-grid {
        grid-template-columns: 1fr;
    }
}

/* ============================================
   PRODUCT CARD - BILKUL SAME STRUCTURE
   ============================================ */
.product-card {
    background-color: #ffffff;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    position: relative;
}

/* Product Count Badge - TOP LEFT CORNER */
.product-count-badge {
    position: absolute;
    top: 15px;
    left: 15px;
    background-color: #1a1a1a;
    color: #ffffff;
    padding: 8px 14px;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 600;
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 6px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
}

.product-count-badge i {
    font-size: 11px;
}

/* Image Zoom Out on Hover */
.image-wrapper {
    overflow: hidden;
    position: relative;
}

.card-image {
    width: 100%;
    height: 280px;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
}

.product-card:hover .card-image {
    transform: scale(0.95);
}

/* Heart Icon - Top Right Corner */
.heart-icon-top {
    position: absolute;
    top: 15px;
    right: 15px;
    width: 36px;
    height: 36px;
    background-color: rgba(255, 255, 255, 0.9);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
    z-index: 10;
}

.heart-icon-top i {
    font-size: 16px;
    color: #070000;
    transition: all 0.3s ease;
}

.heart-icon-top:hover {
    background-color: #ffffff;
    transform: scale(1.1);
}

.heart-icon-top:hover i {
    color: #ff6b9d;
}

.heart-icon-top.active {
    background-color: #e74c3c;
}

.heart-icon-top.active i {
    color: #ffffff;
}

/* Card Content */
.card-content {
    padding: 24px;
    padding-bottom: 80px;
    position: relative;
}

.card-title {
    font-size: 18px;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 12px;
    line-height: 1.3;
}

.card-description {
    font-size: 14px;
    color: #666666;
    line-height: 1.6;
    margin-bottom: 20px;
}

/* Static View Link */
.view-link {
    font-size: 13px;
    font-weight: 600;
    color: #1a1a1a;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
}

.view-link::after {
    content: '→';
    font-size: 14px;
}

/* Wishlist Button - Bottom Left Sticky */
.wishlist-btn {
    position: absolute;
    bottom: 20px;
    left: 24px;
    padding: 10px 20px;
    background-color: #ffffff;
    border: 1px solid #e0e0e0;
    border-radius: 4px;
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    transition: all 0.3s ease;
    font-size: 13px;
    color: #666666;
    font-weight: 500;
    text-decoration: none;
}

.wishlist-btn i {
    font-size: 14px;
}

.wishlist-btn:hover {
    background-color: #fff5f5;
    border-color: #ff6b9d;
    color: #ff6b9d;
}

.wishlist-btn.active {
    background-color: #e74c3c;
    border-color: #e74c3c;
    color: #ffffff;
}

/* Responsive */
@media (max-width: 1024px) {
    .first-collection-card {
        height: 350px;
    }

    .collection-header {
        padding: 30px 30px 0 30px;
    }
}

@media (max-width: 768px) {
    body {
        padding: 20px;
    }

    .first-collection-card {
        height: 300px;
    }

    .collection-header {
        padding: 20px 20px 0 20px;
    }

    .collection-header h1 {
        font-size: 24px;
    }

    .products-grid {
        gap: 15px;
    }

    .card-image {
        height: 250px;
    }

    .card-content {
        padding: 15px;
        padding-bottom: 70px;
    }

    .card-title {
        font-size: 17px;
    }

    .wishlist-btn {
        bottom: 15px;
        left: 15px;
        padding: 8px 16px;
        font-size: 12px;
    }
}
</style>

