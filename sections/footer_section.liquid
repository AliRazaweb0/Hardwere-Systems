
    <!-- Font Awesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f8f8f8;
            padding: 40px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        /* Filter Buttons Section */
        .filter-section {
            margin-bottom: 40px; /* Equal space between buttons and cards */
        }

        .filter-container {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            margin-bottom: 20px;
        }

        .filter-btn {
            padding: 10px 16px;
            border: 1px solid #cccccc;
            background-color: #ffffff;
            color: #333333;
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .filter-btn:hover {
            background-color: #1a1a1a;
            color: #ffffff;
            border-color: #1a1a1a;
        }

        .filter-btn.active {
            background-color: #1a1a1a;
            color: #ffffff;
            border-color: #1a1a1a;
        }

        /* Section Header */
        .section-header {
            margin-top: 20px;
        }

        .section-subtitle {
            color: #888888;
            font-size: 12px;
            letter-spacing: 1px;
            text-transform: uppercase;
            margin-bottom: 8px;
        }

        .section-title {
            color: #1a1a1a;
            font-size: 32px;
            font-weight: bold;
            margin-bottom: 30px; /* Space before cards */
        }

        /* Cards Container */
        .cards-container {
            display: flex;
            gap: 24px;
        }

        .product-card {
            flex: 1;
            background-color: #ffffff;
            border-radius: 4px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
            position: relative;
        }

        /* Image Zoom Out on Hover */
        .image-wrapper {
            overflow: hidden;
            position: relative;
        }

        .card-image {
            width: 100%;
            height: 280px;
            object-fit: cover;
            display: block;
            transition: transform 0.5s ease;
        }

        .product-card:hover .card-image {
            transform: scale(0.95);
        }

        /* Heart Icon - Top Right Corner */
        .heart-icon-top {
            position: absolute;
            top: 15px;
            right: 15px;
            width: 36px;
            height: 36px;
            background-color: rgba(255, 255, 255, 0.9);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
            z-index: 10;
        }

        .heart-icon-top i {
            font-size: 16px;
            color: #070000;
            transition: all 0.3s ease;
        }

        /* Heart Hover - Pink */
        .heart-icon-top:hover {
            background-color: #ffffff;
            transform: scale(1.1);
        }

        .heart-icon-top:hover i {
            color: #ff6b9d;
        }

        /* Heart Active - Red */
        .heart-icon-top.active {
            background-color: #e74c3c;
        }

        .heart-icon-top.active i {
            color: #ffffff;
        }

        .heart-icon-top.active:hover {
            background-color: #c0392b;
        }

        /* Card Content */
        .card-content {
            padding: 24px;
            padding-bottom: 80px; /* Space for wishlist button */
            position: relative;
        }

        .card-title {
            font-size: 18px;
            font-weight: 600;
            color: #1a1a1a;
            margin-bottom: 12px;
            line-height: 1.3;
            /* NO hover effect - static */
        }

        .card-description {
            font-size: 14px;
            color: #666666;
            line-height: 1.6;
            margin-bottom: 20px;
            /* NO hover effect - static */
        }

        /* Static View Link */
        .view-link {
            font-size: 13px;
            font-weight: 600;
            color: #1a1a1a;
            text-decoration: none;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .view-link::after {
            content: '→';
            font-size: 14px;
        }

        /* Wishlist Button - Bottom Left Sticky */
        .wishlist-btn {
            position: absolute;
            bottom: 20px;
            left: 24px;
            padding: 10px 20px;
            background-color: #ffffff;
            border: 1px solid #e0e0e0;
            border-radius: 4px;
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: 13px;
            color: #666666;
            font-weight: 500;
        }

        .wishlist-btn i {
            font-size: 14px;
        }

        /* Wishlist Hover */
        .wishlist-btn:hover {
            background-color: #fff5f5;
            border-color: #ff6b9d;
            color: #ff6b9d;
        }

        /* Wishlist Active */
        .wishlist-btn.active {
            background-color: #e74c3c;
            border-color: #e74c3c;
            color: #ffffff;
        }

        .wishlist-btn.active:hover {
            background-color: #c0392b;
            border-color: #c0392b;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .cards-container {
                flex-direction: column;
            }
            
            .filter-container {
                gap: 6px;
            }
            
            .filter-btn {
                padding: 8px 12px;
                font-size: 12px;
            }
        }
          /* ==================== */
          @media screen and (max-width: 480px) {
            body {
                padding: 20px 15px;
            }

            .filter-section {
                margin-bottom: 25px;
            }

            .filter-container {
                gap: 5px;
                margin-bottom: 12px;
            }

            .filter-btn {
                padding: 6px 12px;
                font-size: 11px;
                flex: 1;
                min-width: calc(50% - 5px);
            }

            .section-header {
                margin-top: 12px;
            }

            .section-subtitle {
                font-size: 10px;
                letter-spacing: 0.5px;
            }

            .section-title {
                font-size: 24px;
                margin-bottom: 20px;
            }

            .cards-container {
                gap: 15px;
            }

            .card-image {
                height: 250px;
            }

            .card-content {
                padding: 15px;
                padding-bottom: 70px;
            }

            .card-title {
                font-size: 17px;
                margin-bottom: 10px;
            }

            .card-description {
                font-size: 13px;
                line-height: 1.5;
                margin-bottom: 12px;
            }

            .view-link {
                font-size: 12px;
            }

            .view-link::after {
                font-size: 12px;
            }

            .heart-icon-top {
                top: 10px;
                right: 10px;
                width: 32px;
                height: 32px;
            }

            .heart-icon-top i {
                font-size: 14px;
            }

            .wishlist-btn {
                bottom: 15px;
                left: 15px;
                padding: 8px 16px;
                font-size: 12px;
            }

            .wishlist-btn i {
                font-size: 12px;
            }
        }

        /* ==================== */
        /* SMALL MOBILE */
        /* ==================== */
        @media screen and (max-width: 320px) {
            .filter-btn {
                font-size: 10px;
                padding: 5px 10px;
            }

            .section-title {
                font-size: 20px;
            }

            .card-image {
                height: 200px;
            }

            .card-title {
                font-size: 15px;
            }

            .card-description {
                font-size: 12px;
            }

            .wishlist-btn {
                padding: 6px 14px;
                font-size: 11px;
            }
        }
    </style>


    <div class="container">
        
        <!-- Filter Buttons Section -->
        <div class="filter-section">
            <div class="filter-container">
                <button class="filter-btn active">All Systems</button>
                <button class="filter-btn">Balustrade & Pool</button>
                <button class="filter-btn">Sliding Door</button>
                <button class="filter-btn">Shower</button>
                <button class="filter-btn">Canopy & Facade</button>
                <button class="filter-btn">Commercial Doors & Partitions</button>
            </div>

            <!-- Section Header -->
            <div class="section-header">
                <p class="section-subtitle">11 Systems Available</p>
                <h1 class="section-title">Systems</h1>
            </div>
        </div>

        <!-- Cards Container -->
        <div class="cards-container">
            
            <!-- Card 1 -->
            <div class="product-card">
                <div class="image-wrapper">
                    <img src="https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?w=800&h=600&fit=crop" 
                         alt="SmartLock Channel" class="card-image">
                    
                    <!-- Heart Icon Top Right -->
                    <div class="heart-icon-top" onclick="toggleHeart(this)" title="Like">
                        <i class="fas fa-heart"></i>
                    </div>
                </div>
                
                <div class="card-content">
                    <h3 class="card-title">SmartLock™ Channel</h3>
                    <p class="card-description">Minimalist frameless glass panels with concealed channel fixings.</p>
                    <a href="#" class="view-link">VIEW SYSTEM</a>
                    
                    <!-- Wishlist Button Bottom Left -->
                    <button class="wishlist-btn" onclick="toggleWishlist(this)">
                        <i class="fas fa-bookmark"></i>
                        <span>Wishlist</span>
                    </button>
                </div>
            </div>

            <!-- Card 2 -->
            <div class="product-card">
                <div class="image-wrapper">
                    <img src="https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=800&h=600&fit=crop" 
                         alt="Semi-Frameless Balustrade" class="card-image">
                    
                    <!-- Heart Icon Top Right -->
                    <div class="heart-icon-top" onclick="toggleHeart(this)" title="Like">
                        <i class="fas fa-heart"></i>
                    </div>
                </div>
                
                <div class="card-content">
                    <h3 class="card-title">Semi-Frameless Balustrade</h3>
                    <p class="card-description">Elegant semi-frameless system with slim post profiles.</p>
                    <a href="#" class="view-link">VIEW SYSTEM</a>
                    
                    <!-- Wishlist Button Bottom Left -->
                    <button class="wishlist-btn" onclick="toggleWishlist(this)">
                        <i class="fas fa-bookmark"></i>
                        <span>Wishlist</span>
                    </button>
                </div>
            </div>

            <!-- Card 3 -->
            <div class="product-card">
                <div class="image-wrapper">
                    <img src="https://images.unsplash.com/photo-1572331165267-854da2b10ccc?w=800&h=600&fit=crop" 
                         alt="Pool Fencing System" class="card-image">
                    
                    <!-- Heart Icon Top Right -->
                    <div class="heart-icon-top" onclick="toggleHeart(this)" title="Like">
                        <i class="fas fa-heart"></i>
                    </div>
                </div>
                
                <div class="card-content">
                    <h3 class="card-title">Pool Fencing System</h3>
                    <p class="card-description">Compliant glass pool fencing with durable marine-grade hardware.</p>
                    <a href="#" class="view-link">VIEW SYSTEM</a>
                    
                    <!-- Wishlist Button Bottom Left -->
                    <button class="wishlist-btn" onclick="toggleWishlist(this)">
                        <i class="fas fa-bookmark"></i>
                        <span>Wishlist</span>
                    </button>
                </div>
            </div>

        </div>

    </div>

    <script>
        // Heart toggle function
        function toggleHeart(element) {
            element.classList.toggle('active');
            
            if (element.classList.contains('active')) {
                console.log('Liked!');
            } else {
                console.log('Unliked!');
            }
        }

        // Wishlist toggle function
        function toggleWishlist(element) {
            element.classList.toggle('active');
            const icon = element.querySelector('i');
            const text = element.querySelector('span');
            
            if (element.classList.contains('active')) {
                text.textContent = 'Saved';
                console.log('Added to wishlist!');
            } else {
                text.textContent = 'Wishlist';
                console.log('Removed from wishlist!');
            }
        }
    </script>


