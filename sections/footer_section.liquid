<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background-color: #f8f8f8;
    padding: 40px;
}

.container {
    max-width: 1200px;
    margin: 0 auto;
}

/* Filter Buttons Section */
.filter-section {
    margin-bottom: 40px;
}

.filter-container {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 20px;
}

.filter-btn {
    padding: 10px 16px;
    border: 1px solid #cccccc;
    background-color: #ffffff;
    color: #333333;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
}

.filter-btn:hover {
    background-color: #1a1a1a;
    color: #ffffff;
    border-color: #1a1a1a;
}

.filter-btn.active {
    background-color: #1a1a1a;
    color: #ffffff;
    border-color: #1a1a1a;
}

/* Section Header */
.section-header {
    margin-top: 20px;
}

.section-subtitle {
    color: #888888;
    font-size: 12px;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-bottom: 8px;
}

.section-title {
    color: #1a1a1a;
    font-size: 32px;
    font-weight: bold;
    margin-bottom: 30px;
}

/* ============================================
   PRODUCTS GRID - 3 PER ROW
   ============================================ */
.cards-container {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
}

@media (max-width: 1024px) {
    .cards-container {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media (max-width: 768px) {
    .cards-container {
        grid-template-columns: 1fr;
    }
}

/* ============================================
   PRODUCT CARD - TUMHARA BILKUL SAME LAYOUT
   ============================================ */
.product-card {
    background-color: #ffffff;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    position: relative;
}

/* Product Count Badge - TOP LEFT CORNER */
.product-count-badge {
    position: absolute;
    top: 15px;
    left: 15px;
    background-color: #1a1a1a;
    color: #ffffff;
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 5px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
}

.product-count-badge i {
    font-size: 10px;
}

/* Image Zoom Out on Hover */
.image-wrapper {
    overflow: hidden;
    position: relative;
}

.card-image {
    width: 100%;
    height: 280px;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
}

.product-card:hover .card-image {
    transform: scale(0.95);
}

/* Heart Icon - Top Right Corner */
.heart-icon-top {
    position: absolute;
    top: 15px;
    right: 15px;
    width: 36px;
    height: 36px;
    background-color: rgba(255, 255, 255, 0.9);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
    z-index: 10;
}

.heart-icon-top i {
    font-size: 16px;
    color: #070000;
    transition: all 0.3s ease;
}

.heart-icon-top:hover {
    background-color: #ffffff;
    transform: scale(1.1);
}

.heart-icon-top:hover i {
    color: #ff6b9d;
}

.heart-icon-top.active {
    background-color: #e74c3c;
}

.heart-icon-top.active i {
    color: #ffffff;
}

/* Card Content */
.card-content {
    padding: 24px;
    padding-bottom: 80px;
    position: relative;
}

.card-title {
    font-size: 18px;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 12px;
    line-height: 1.3;
}

.card-description {
    font-size: 14px;
    color: #666666;
    line-height: 1.6;
    margin-bottom: 20px;
}

/* Static View Link */
.view-link {
    font-size: 13px;
    font-weight: 600;
    color: #1a1a1a;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
}

.view-link::after {
    content: '→';
    font-size: 14px;
}

/* Wishlist Button - Bottom Left Sticky */
.wishlist-btn {
    position: absolute;
    bottom: 20px;
    left: 24px;
    padding: 10px 20px;
    background-color: #ffffff;
    border: 1px solid #e0e0e0;
    border-radius: 4px;
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    transition: all 0.3s ease;
    font-size: 13px;
    color: #666666;
    font-weight: 500;
}

.wishlist-btn i {
    font-size: 14px;
}

.wishlist-btn:hover {
    background-color: #fff5f5;
    border-color: #ff6b9d;
    color: #ff6b9d;
}

.wishlist-btn.active {
    background-color: #e74c3c;
    border-color: #e74c3c;
    color: #ffffff;
}

/* Responsive */
@media (max-width: 768px) {
    body {
        padding: 20px;
    }

    .cards-container {
        gap: 15px;
    }

    .card-image {
        height: 250px;
    }

    .card-content {
        padding: 15px;
        padding-bottom: 70px;
    }

    .card-title {
        font-size: 17px;
    }

    .wishlist-btn {
        bottom: 15px;
        left: 15px;
        padding: 8px 16px;
        font-size: 12px;
    }

    .heart-icon-top {
        top: 10px;
        right: 10px;
        width: 32px;
        height: 32px;
    }

    .heart-icon-top i {
        font-size: 14px;
    }

    .product-count-badge {
        top: 10px;
        left: 10px;
        padding: 5px 10px;
        font-size: 11px;
    }

    .filter-btn {
        padding: 8px 12px;
        font-size: 12px;
    }

    .section-title {
        font-size: 24px;
    }
}

@media (max-width: 480px) {
    .filter-btn {
        flex: 1;
        min-width: calc(50% - 5px);
    }
}
</style>

<div class="container">

    <!-- Filter Buttons Section -->
    <div class="filter-section">
        <div class="filter-container">
            <button class="filter-btn active" onclick="filterProducts('all')">All Systems</button>
            <button class="filter-btn" onclick="filterProducts('balustrade')">Balustrade & Pool</button>
            <button class="filter-btn" onclick="filterProducts('sliding')">Sliding Door</button>
            <button class="filter-btn" onclick="filterProducts('shower')">Shower</button>
