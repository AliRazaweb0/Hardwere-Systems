<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
}

body {
    background-color: #f8f8f8;
    padding: 40px;
}

.container {
    max-width: 1200px;
    margin: 0 auto;
}

/* Section Header */
.section-header {
    margin-bottom: 30px;
}

.section-subtitle {
    color: #888888;
    font-size: 12px;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-bottom: 8px;
}

.section-title {
    color: #1a1a1a;
    font-size: 32px;
    font-weight: bold;
}

/* Products Grid - 3 Per Row */
.products-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
}

@media (max-width: 1024px) {
    .products-grid {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media (max-width: 768px) {
    .products-grid {
        grid-template-columns: 1fr;
    }
}

/* Product Card */
.product-card {
    background-color: #ffffff;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    position: relative;
}

/* Product Count Badge - TOP LEFT */
.product-count-badge {
    position: absolute;
    top: 15px;
    left: 15px;
    background-color: #1a1a1a;
    color: #ffffff;
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 5px;
}

/* Image Wrapper */
.image-wrapper {
    overflow: hidden;
    position: relative;
}

.card-image {
    width: 100%;
    height: 280px;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
}

.product-card:hover .card-image {
    transform: scale(0.95);
}

/* Heart Icon - Top Right */
.heart-icon-top {
    position: absolute;
    top: 15px;
    right: 15px;
    width: 36px;
    height: 36px;
    background-color: rgba(255, 255, 255, 0.9);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
    z-index: 10;
}

.heart-icon-top:hover {
    background-color: #ffffff;
    transform: scale(1.1);
}

.heart-icon-top:hover i {
    color: #ff6b9d;
}

.heart-icon-top.active {
    background-color: #e74c3c;
}

.heart-icon-top.active i {
    color: #ffffff;
}

/* Card Content */
.card-content {
    padding: 24px;
    padding-bottom: 80px;
    position: relative;
}

.card-title {
    font-size: 18px;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 12px;
}

.card-description {
    font-size: 14px;
    color: #666666;
    line-height: 1.6;
    margin-bottom: 20px;
}

/* View Link */
.view-link {
    font-size: 13px;
    font-weight: 600;
    color: #1a1a1a;
    text-decoration: none;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 8px;
}

.view-link::after {
    content: '→';
    font-size: 14px;
}

/* Wishlist Button */
.wishlist-btn {
    position: absolute;
    bottom: 20px;
    left: 24px;
    padding: 10px 20px;
    background-color: #ffffff;
    border: 1px solid #e0e0e0;
    border-radius: 4px;
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    transition: all 0.3s ease;
    font-size: 13px;
    color: #666666;
    font-weight: 500;
}

.wishlist-btn:hover {
    background-color: #fff5f5;
    border-color: #ff6b9d;
    color: #ff6b9d;
}

.wishlist-btn.active {
    background-color: #e74c3c;
    border-color: #e74c3c;
    color: #ffffff;
}
</style>

<div class="container">

    <div class="section-header">
        <p class="section-subtitle">{{ collections.first.products.size }} Systems Available</p>
        <h1 class="section-title">Systems</h1>
    </div>

    <div class="products-grid">

        {% for product in collections.first.products %}
            <div class="product-card">
                <div class="image-wrapper">
                    <div class="product-count-badge">
                        <i class="fas fa-hashtag"></i>
                        <span>{{ forloop.index }}</span>
                    </div>

                    <img src="{{ product.featured_image | image_url: width: 800 }}" 
                         alt="{{ product.title }}" 
                         class="card-image">

                    <div class="heart-icon-top" onclick="toggleHeart(this)">
                        <i class="fas fa-heart"></i>
                    </div>
                </div>

                <div class="card-content">
                    <h3 class="card-title">{{ product.title }}</h3>
                    <p class="card-description">{{ product.description | strip_html | truncate: 120 }}</p>
                    <a href="{{ product.url }}" class="view-link">VIEW SYSTEM</a>

                    <button class="wishlist-btn" onclick="toggleWishlist(this)">
                        <i class="fas fa-bookmark"></i>
                        <span>Wishlist</span>
                    </button>
                </div>
            </div>
        {% endfor %}

    </div>

</div>

<script>
    function toggleHeart(element) {
        element.classList.toggle('active');
    }

    function toggleWishlist(element) {
        element.classList.toggle('active');
        const text = element.querySelector('span');
        text.textContent = element.classList.contains('active') ? 'Saved' : 'Wishlist';
    }
</script>

{% schema %}
{
  "name": "Products Grid",
  "settings": [],
  "presets": [
    {
      "name": "Products Grid"
    }
  ]
}
{% endschema %}