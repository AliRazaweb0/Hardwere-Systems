<!-- Filter Section -->
<div class="filter-section">
    <div class="filter-container">
        <button class="filter-btn active" data-filter="all">All Systems</button>
        <button class="filter-btn" data-filter="balustrade">Balustrade & Pool</button>
        <button class="filter-btn" data-filter="sliding">Sliding Door</button>
        <button class="filter-btn" data-filter="shower">Shower</button>
        <button class="filter-btn" data-filter="canopy">Canopy & Facade</button>
        <button class="filter-btn" data-filter="commercial">Commercial Doors & Partitions</button>
    </div>

    <!-- Section Header -->
    <div class="section-header">
        <p class="section-subtitle"><span id="product-count">0</span> Systems Available</p>
        <h1 class="section-title">Systems</h1>
    </div>
</div>

<!-- Cards Container -->
<div class="cards-container">
  {% for product in collections.all.products %}
    <div class="product-card" data-category="{{ product.metafields.custom.category | default: 'all' }}">
        <div class="image-wrapper">
            <img src="{{ product.featured_image | img_url: '600x400' }}" 
                 alt="{{ product.title }}" class="card-image">

            <!-- Heart Icon Top Right -->
            <div class="heart-icon-top" onclick="toggleHeart(this)" title="Like">
                <i class="fas fa-heart"></i>
            </div>
        </div>
        

        <div class="card-content">
            <!-- Product Title -->
            <h3 class="card-title">{{ product.title }}</h3>

            <!-- Product Description -->
            <p class="card-description">{{ product.description | strip_html | truncate: 80 }}</p>

            <!-- View System Button -->
            <a href="{{ product.url }}" class="view-link">VIEW SYSTEM</a>

            <!-- Wishlist Button -->
            <button class="wishlist-btn" onclick="toggleWishlist(this)">
                <i class="fas fa-bookmark"></i>
                <span>Wishlist</span>
            </button>
        </div>
    </div>
  {% endfor %}
</div>

<style>
/* Filter Section Styling */
.filter-section {
    max-width: 1200px;
    margin: 0 auto 30px auto;
    padding: 0 15px;
}

/* Filter Buttons Row */
.filter-container {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 25px;
    justify-content: flex-start;
}

.filter-btn {
    padding: 10px 20px;
    background-color: #fff;
    border: 2px solid #1a1a1a;
    border-radius: 30px;
    font-size: 13px;
    font-weight: 600;
    color: #1a1a1a;
    cursor: pointer;
    transition: all 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.filter-btn:hover {
    background-color: #1a1a1a;
    color: #fff;
}

.filter-btn.active {
    background-color: #1a1a1a;
    color: #fff;
}

/* Section Header - Subtitle and Title */
.section-header {
    text-align: left;
    margin-bottom: 10px;
}

.section-subtitle {
    font-size: 14px;
    color: #666;
    margin-bottom: 5px;
    font-weight: 500;
    letter-spacing: 0.5px;
}

.section-title {
    font-size: 36px;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 1px;
}

/* Cards Container */
.cards-container {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
}

/* Product Card */
.product-card {
   flex: 1 1 calc(33.333% - 16px);
    background-color: #ffffff;
    border-radius: 6px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    display: flex;
    flex-direction: column;
    position: relative;
    transition: all 0.3s ease;
}

.product-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.12);
}

/* Image Wrapper & Zoom */
.image-wrapper {
    overflow: hidden;
    position: relative;
}

.card-image {
    width: 100%;
    height: 280px;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
}

.product-card:hover .card-image {
    transform: scale(0.95);
}

/* Heart Icon */
.heart-icon-top {
    position: absolute;
    top: 15px;
    right: 15px;
    width: 36px;
    height: 36px;
    background-color: rgba(255,255,255,0.9);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
    z-index: 10;
    transition: all 0.3s ease;
}

.heart-icon-top i {
    font-size: 16px;
    color: #070000;
    transition: all 0.3s ease;
}

.heart-icon-top:hover i { color: #ff6b9d; }
.heart-icon-top.active {
    background-color: #e74c3c;
}
.heart-icon-top.active i { color: #fff; }

/* Card Content */
.card-content {
    padding: 24px;
    padding-bottom: 80px; /* For wishlist button */
    flex-grow: 1;
}

.card-title {
    font-size: 18px;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 12px;
}

.card-description {
    font-size: 14px;
    color: #666;
    line-height: 1.6;
    margin-bottom: 20px;
}

/* View Link */
.view-link {
    font-size: 13px;
    font-weight: 600;
    color: #1a1a1a;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
}

.view-link::after {
    content: '→';
    font-size: 14px;
}

/* Wishlist Button */
.wishlist-btn {
    position: absolute;
    bottom: 20px;
    left: 24px;
    padding: 10px 20px;
    background-color: #fff;
    border: 1px solid #e0e0e0;
    border-radius: 4px;
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    transition: all 0.3s ease;
    font-size: 13px;
    color: #666;
    font-weight: 500;
}

.wishlist-btn i { font-size: 14px; }
.wishlist-btn:hover {
    background-color: #fff5f5;
    border-color: #ff6b9d;
    color: #ff6b9d;
}

.wishlist-btn.active {
    background-color: #e74c3c;
    border-color: #e74c3c;
    color: #fff;
}

/* Responsive */
@media (max-width: 1024px) {
    .product-card { flex: 1 1 calc(50% - 16px); }
}

@media (max-width: 768px) {
    .product-card { flex: 1 1 100%; }
}
</style>

<script>
// Product Count Function
document.addEventListener('DOMContentLoaded', function() {
    // Count total products
    var productCards = document.querySelectorAll('.product-card');
    var totalProducts = productCards.length;

    // Update the count in subtitle
    var countElement = document.getElementById('product-count');
    if (countElement) {
        countElement.textContent = totalProducts;
    }

    // Filter functionality
    var filterButtons = document.querySelectorAll('.filter-btn');

    filterButtons.forEach(function(button) {
        button.addEventListener('click', function() {
            // Remove active class from all buttons
            filterButtons.forEach(function(btn) {
                btn.classList.remove('active');
            });

            // Add active class to clicked button
            this.classList.add('active');

            var filterValue = this.getAttribute('data-filter');
            var visibleCount = 0;

            productCards.forEach(function(card) {
                if (filterValue === 'all') {
                    card.style.display = 'block';
                    visibleCount++;
                } else {
                    var cardCategory = card.getAttribute('data-category');
                    if (cardCategory === filterValue) {
                        card.style.display = 'block';
                        visibleCount++;
                    } else {
                        card.style.display = 'none';
                    }
                }
            });

            // Update count based on visible products
            if (countElement) {
                countElement.textContent = visibleCount;
            }
        });
    });
});

// Heart toggle function
function toggleHeart(element) {
    element.classList.toggle('active');
}

// Wishlist toggle function
function toggleWishlist(button) {
    button.classList.toggle('active');
    var span = button.querySelector('span');
    if (button.classList.contains('active')) {
        span.textContent = 'Added';
    } else {
        span.textContent = 'Wishlist';
    }
}
</script>