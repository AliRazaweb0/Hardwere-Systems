<!-- Cards Container -->
<div class="cards-container">
  {% for product in collections.all.products %}
    <div class="product-card">
        <div class="image-wrapper">
            <img src="{{ product.featured_image | img_url: '800x600' }}" 
                 alt="{{ product.title }}" class="card-image">
            
            <!-- Heart Icon Top Right -->
            <div class="heart-icon-top" onclick="toggleHeart(this)" title="Like">
                <i class="fas fa-heart"></i>
            </div>
        </div>
        
        <div class="card-content">
            <!-- Product Title -->
            <h3 class="card-title">{{ product.title }}</h3>

            <!-- Product Description -->
            <p class="card-description">{{ product.description | strip_html | truncate: 100 }}</p>

            <!-- View System Button -->
            <a href="{{ product.url }}" class="view-link">VIEW SYSTEM</a>
            
            <!-- Wishlist Button -->
            <button class="wishlist-btn" onclick="toggleWishlist(this)">
                <i class="fas fa-bookmark"></i>
                <span>Wishlist</span>
            </button>
        </div>
    </div>
  {% endfor %}
</div>

<style>
/* ===========================
   Cards Layout
=========================== */
.cards-container {
    display: flex;
    flex-wrap: wrap;
    gap: 12px; /* Reduced gap between cards */
    justify-content: space-between;
}

.product-card {
    flex: 1 1 calc(30% - 10px); /* Slightly smaller width, 3 per row */
    max-width: calc(30% - 10px);
    background-color: #fff;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 6px 18px rgba(0,0,0,0.08);
    transition: transform 0.3s, box-shadow 0.3s;
    position: relative;
}

.product-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 24px rgba(0,0,0,0.12);
}

/* ===========================
   Card Image
=========================== */
.card-image {
    width: 100%;
    height: 250px;
    object-fit: cover;
    transition: transform 0.5s ease;
}

.product-card:hover .card-image {
    transform: scale(1.05);
}

/* ===========================
   Heart Icon
=========================== */
.heart-icon-top {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 36px;
    height: 36px;
    background-color: rgba(255, 255, 255, 0.9);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 2px 6px rgba(0,0,0,0.15);
    transition: all 0.3s;
    z-index: 20; /* Increased z-index to make sure icon shows */
}

.heart-icon-top i {
    font-size: 16px;
    color: #333;
    transition: color 0.3s;
}

.heart-icon-top:hover i {
    color: #ff6b9d;
}

.heart-icon-top.active {
    background-color: #e74c3c;
}

.heart-icon-top.active i {
    color: #fff;
}

/* ===========================
   Card Content
=========================== */
.card-content {
    padding: 20px;
    padding-bottom: 60px; /* space for wishlist button */
    position: relative;
}

.card-title {
    font-size: 18px;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 10px;
}

.card-description {
    font-size: 14px;
    color: #666;
    line-height: 1.5;
    margin-bottom: 15px;
}

/* ===========================
   View System Button
=========================== */
.view-link {
    display: inline-block;
    text-decoration: none;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 13px;
    color: #fff;
    background-color: #1a1a1a;
    padding: 8px 16px;
    border-radius: 4px;
    transition: all 0.3s;
    margin-bottom: 10px;
}

.view-link:hover {
    background-color: #ff6b9d;
}

/* ===========================
   Wishlist Button
=========================== */
.wishlist-btn {
    position: absolute;
    bottom: 20px;
    left: 20px;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    background-color: #fff;
    border: 1px solid #ddd;
    border-radius: 4px;
    font-size: 13px;
    color: #666;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s;
    z-index: 15;
}

.wishlist-btn i {
    font-size: 14px;
}

.wishlist-btn:hover {
    background-color: #ff6b9d;
    border-color: #ff6b9d;
    color: #fff;
}

.wishlist-btn.active {
    background-color: #e74c3c;
    border-color: #e74c3c;
    color: #fff;
}

/* ===========================
   Responsive
=========================== */
@media (max-width: 1024px) {
    .product-card {
        flex: 1 1 calc(48% - 6px); /* 2 cards per row tablet */
        max-width: calc(48% - 6px);
    }
}

@media (max-width: 768px) {
    .product-card {
        flex: 1 1 100%; /* 1 card per row mobile */
        max-width: 100%;
    }
}
</style>