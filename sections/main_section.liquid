<style>
/* (tumhara pura CSS bilkul same rahega — koi change nahi) */
</style>

<div class="header">
    <p class="subtitle">BROWSE BY CATEGORY</p>
    <h1>System Categories</h1>
</div>

<div class="main-container">

    {% assign blocks = section.blocks %}

    <!-- PIC 1 -->
    <div class="pic1" style="background-image: url({{ blocks[0].settings.collection.image | image_url }})">
        <a href="{{ blocks[0].settings.collection.url }}">
            <div class="text">
                <h3>{{ blocks[0].settings.collection.title }}</h3>
                <p>Premium glass balustrade and pool fencing systems for residential and commercial projects.</p>
                <span>EXPLORE SYSTEMS →</span>
            </div>
        </a>
    </div>

    <!-- PIC 2 -->
    <div class="pic2" style="background-image: url({{ blocks[1].settings.collection.image | image_url }})">
        <a href="{{ blocks[1].settings.collection.url }}">
            <div class="text">
                <h3>{{ blocks[1].settings.collection.title }}</h3>
                <p>High-performance sliding door track and hardware systems for seamless indoor-outdoor living.</p>
                <span>EXPLORE SYSTEMS →</span>
            </div>
        </a>
    </div>

    <!-- PIC 3 -->
    <div class="pic3" style="background-image: url({{ blocks[2].settings.collection.image | image_url }})">
        <a href="{{ blocks[2].settings.collection.url }}">
            <div class="text">
                <h3>{{ blocks[2].settings.collection.title }}</h3>
                <p>Precision-engineered shower screen hardware and enclosure systems for modern bathrooms.</p>
                <span>EXPLORE SYSTEMS →</span>
            </div>
        </a>
    </div>

    <!-- PIC 4 -->
    <div class="pic4" style="background-image: url({{ blocks[3].settings.collection.image | image_url }})">
        <a href="{{ blocks[3].settings.collection.url }}">
            <div class="text">
                <h3>{{ blocks[3].settings.collection.title }}</h3>
                <p>Structural glass canopy and facade fixing systems for striking architectural statements.</p>
                <span>EXPLORE SYSTEMS →</span>
            </div>
        </a>
    </div>

    <!-- PIC 5 -->
    <div class="pic5" style="background-image: url({{ blocks[4].settings.collection.image | image_url }})">
        <a href="{{ blocks[4].settings.collection.url }}">
            <div class="text">
                <h3>{{ blocks[4].settings.collection.title }}</h3>
                <p>Heavy-duty commercial door and glass partition systems for offices, retail and hospitality.</p>
                <span>EXPLORE SYSTEMS →</span>
            </div>
        </a>
    </div>

</div>

{% schema %}
{
  "name": "Mainsection",
  "settings": [],
  "blocks": [
    {
      "type": "collection_block",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Select Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Mainsection",
      "blocks": [
        { "type": "collection_block" },
        { "type": "collection_block" },
        { "type": "collection_block" },
        { "type": "collection_block" },
        { "type": "collection_block" }
      ]
    }
  ]
}
{% endschema %}