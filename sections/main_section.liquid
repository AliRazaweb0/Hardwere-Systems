<!-- =============================
CLEAN SHOPIFY COLLECTION + PRODUCT FILTER (NO RELOAD)
============================= -->

<style>
    .main-container {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
        padding: 40px;
    }
    
    .main-container > div:first-child {
        grid-column: span 2;
        height: 400px;
    }
    
    .collection-card {
        position: relative;
        height: 250px;
        border-radius: 10px;
        overflow: hidden;
        background-size: cover;
        background-position: center;
        cursor: pointer;
    }
    
    .collection-card::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
    }
    
    .text {
        position: absolute;
        bottom: 20px;
        left: 20px;
        color: #fff;
        z-index: 2;
    }
    
    .cards-container {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        padding: 40px;
    }
    
    .product-card {
        width: calc(33.33% - 14px);
        background: #fff;
        border-radius: 10px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }
    
    .product-card img {
        width: 100%;
        height: 200px;
        object-fit: cover;
    }
    
    .card-content {
        padding: 15px;
    }
    
    .filter-container {
        padding: 20px 40px;
    }
    
    .filter-btn {
        padding: 8px 14px;
        border: 1px solid #ccc;
        cursor: pointer;
        margin-right: 5px;
    }
    
    .filter-btn.active {
        background: black;
        color: white;
    }
    </style>
    
    <!-- COLLECTIONS -->
    <div class="main-container">
    {% for collection in collections %}
      <div class="collection-card"
           onclick="handleCollectionClick(event, '{{ collection.title }}')"
           data-category="{{ collection.title }}"
           style="background-image:url('{{ collection.image | image_url: width: 1000 }}')">
    
        <div class="text">
          <h3>{{ collection.title }}</h3>
        </div>
      </div>
    {% endfor %}
    </div>
    
    <!-- FILTER BUTTONS -->
    <div class="filter-container">
      <button class="filter-btn active" data-category="all">All</button>
      {% for collection in collections %}
        <button class="filter-btn" data-category="{{ collection.title }}">{{ collection.title }}</button>
      {% endfor %}
    </div>
    
    <!-- PRODUCTS -->
    <div class="cards-container">
    {% for product in collections.all.products %}
      <div class="product-card" data-category="{{ product.collections.first.title }}">
        <img src="{{ product.featured_image | img_url: '600x600' }}">
        <div class="card-content">
          <h4>{{ product.title }}</h4>
          <a href="{{ product.url }}">View</a>
        </div>
      </div>
    {% endfor %}
    </div>
    
  const filterButtons = document.querySelectorAll('.filter-btn');
const productCards = document.querySelectorAll('.product-card');

function activateFilter(category) {
    filterButtons.forEach(btn => btn.classList.remove('active'));

    const targetBtn = Array.from(filterButtons).find(btn => 
        btn.dataset.category === category
    );

    if (targetBtn) targetBtn.classList.add('active');

    productCards.forEach(card => {
        if (category === 'all' || card.dataset.category === category) {
            card.style.display = 'flex';
        } else {
            card.style.display = 'none';
        }
    });
}

// URL se category lena
const params = new URLSearchParams(window.location.search);
const categoryFromURL = params.get('category');

if (categoryFromURL) {
    activateFilter(categoryFromURL);
} else {
    activateFilter('all');
}

// Button click
filterButtons.forEach(btn => {
    btn.addEventListener('click', (e) => {
        e.preventDefault();
        const category = btn.dataset.category;

        // URL update without reload
        history.pushState(null, '', '?category=' + category);

        activateFilter(category);
    });
});
    
    {% schema %}
    {
      "name": "Collection Filter Clean",
      "settings": [],
      "presets": [{"name": "Collection Filter Clean"}]
    }
    {% endschema %}
    