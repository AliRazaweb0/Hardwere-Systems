<style>
    * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: Arial, sans-serif;
}

body {
    background: #f5f5f5;
}

.header {
    padding: 40px 40px 0 40px;
}

.header .subtitle {
    font-size: 11px;
    letter-spacing: 3px;
    color: #888;
    margin-bottom: 8px;
}

.header h1 {
    font-size: 30px;
    color: #222;
}

.main-container {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-template-rows: repeat(2, 180px) repeat(2, 275px);
    gap: 20px;
    padding: 40px;
}

.main-container > div {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 10px;
    overflow: hidden;
    color: #fff;
    background-size: cover;
    background-position: center;
}

.pic1 {
    grid-column: span 2;
    grid-row: span 2;
    background-image: url(https://cdn.shopify.com/s/files/1/0808/8528/5103/files/imgs_5_1b4cd586-c49b-48d3-92b2-ef5b20a9933e.jpg?v=1774520245);
}

.pic2 { background-image: url(https://cdn.shopify.com/s/files/1/0808/8528/5103/files/imgs_5_1b4cd586-c49b-48d3-92b2-ef5b20a9933e.jpg?v=1774520245); }
.pic3 { background-image: url(https://cdn.shopify.com/s/files/1/0808/8528/5103/files/imgs_3.jpg?v=1774517467); }
.pic4 { background-image: url(https://cdn.shopify.com/s/files/1/0808/8528/5103/files/imgs_6.jpg?v=1774517468); }
.pic5 { background-image: url("https://images.unsplash.com/photo-1600585152915-d208bec867a1?w=800&q=80"); }

.main-container > div::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
    z-index: 1;
}

.text {
    position: absolute;
    bottom: 25px;
    left: 25px;
    z-index: 2;
    max-width: 80%;
}

.text h3 {
    font-size: 22px;
    font-weight: bold;
    margin-bottom: 8px;
}

.text p {
    font-size: 14px;
    opacity: 0.9;
}

.text span {
    display: inline-block;
    margin-top: 10px;
    font-size: 13px;
    font-weight: bold;
}

.main-container > div:hover {
    transform: scale(1.04);
    transition: 0.4s;
    cursor: pointer;
}

</style>
<div class="header">
        <p class="subtitle">BROWSE BY CATEGORY</p>
        <h1>System Categories</h1>
    </div>

    <div class="main-container">
        <div class="pic1">
            <div class="text">
                <h3>Balustrade & Pool</h3>
                <p>Premium glass balustrade and pool fencing systems for residential and commercial projects.</p>
                <span>EXPLORE SYSTEMS →</span>
            </div>
        </div>

        <div class="pic2">
            <div class="text">
                <h3>Sliding Door</h3>
                <p>High-performance sliding door track and hardware systems for seamless indoor-outdoor living.</p>
                <span>EXPLORE SYSTEMS →</span>
            </div>
        </div>

        <div class="pic3">
            <div class="text">
                <h3>Shower</h3>
                <p>Precision-engineered shower screen hardware and enclosure systems for modern bathrooms.</p>
                <span>EXPLORE SYSTEMS →</span>
            </div>
        </div>

        <div class="pic4">
            <div class="text">
                <h3>Canopy & Facade</h3>
                <p>Structural glass canopy and facade fixing systems for striking architectural statements.</p>
                <span>EXPLORE SYSTEMS →</span>
            </div>
        </div>

        <div class="pic5">
            <div class="text">
                <h3>Commercial Doors & Partitions</h3>
                <p>Heavy-duty commercial door and glass partition systems for offices, retail and hospitality.</p>
                <span>EXPLORE SYSTEMS →</span>
            </div>
        </div>
    </div>
 {% schema %}
