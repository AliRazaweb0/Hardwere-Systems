<!-- FONT AWESOME -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
body {
    font-family: Arial, sans-serif;
    background: #f8f8f8;
    padding: 40px;
}

/* ===== HEADINGS ===== */
.section-subtitle {
    margin-top: 12px;
    margin-bottom: 0; /* remove bottom space */
    font-size: 12px;
}
/* Systems Heading */
.section-title {
    font-size: 30px; /* thoda balanced */
}

/* ===== COLLECTION HEADER ===== */
.collection-header {
    margin-top: 100px;
    margin-bottom:50px
}

.collection-subtitle {
    margin-top: 12px;
    margin-bottom: 0; /* remove bottom space */
    font-size: 12px;
}


/* System Categories */
.collection-title {
    font-size: 30px; /* pehle ~30px tha → ab 10px kam */
    margin-top: 0;
    margin-bottom: 0;
}

/* ===== COLLECTION GRID ===== */
.main-container {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-bottom: 30px;
}

.main-container > div:first-child {
    grid-column: span 2;
    height: 400px;
}

.collection-card {
    height: 250px;
    border-radius: 10px;
    background-size: cover;
    background-position: center;
    position: relative;
    cursor: pointer;
}

.collection-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
}

.collection-text {
    position: absolute;
    bottom: 20px;
    left: 20px;
    color: white;
}

/* ===== FILTER BUTTON ===== */
.filter-container {
    margin-bottom: 20px;
}

.filter-btn {
    padding: 8px 14px;
    border: 1px solid #ccc;
    cursor: pointer;
    margin-right: 5px;
    background: white;
}

.filter-btn.active {
    background: black;
    color: white;
}

/* ===== PRODUCT CARDS ===== */
.cards-container {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
}

.product-card {
    width: calc(33.33% - 14px);
    background: white;
    border-radius: 10px;
    overflow: hidden;
}

.image-wrapper {
    position: relative;
}

.card-image {
    width: 100%;
    height: 220px;
    object-fit: cover;
}

/* HEART ICON */
.heart-icon-top {
    position: absolute;
    top: 10px;
    right: 10px;
    background: white;
    padding: 8px;
    border-radius: 50%;
    cursor: pointer;
}

.heart-icon-top.active {
    color: red;
}

/* CONTENT */
.card-content {
    padding: 15px;
}

.view-link {
    display: inline-block;
    margin-top: 10px;
    color: blue;
}

/* WISHLIST */
.wishlist-btn {
    margin-top: 10px;
    padding: 8px;
    border: none;
    background: #eee;
    cursor: pointer;
}

.wishlist-btn.active {
    background: red;
    color: white;
}
</style>

<!-- =============================
COLLECTION HEADER
============================= -->
<div class="collection-header">
    <p class="collection-subtitle">BROWSE BY CATEGORY</p>
    <h1 class="collection-title">System Categories</h1>
</div>

<!-- =============================
COLLECTION CARDS
============================= -->
<div class="main-container">
{% for collection in collections %}
  <div class="collection-card"
       data-category="{{ collection.handle }}"
       style="background-image:url('{{ collection.image | image_url: width: 1000 }}')">

    <div class="collection-text">
      <h3>{{ collection.title }}</h3>
    </div>
  </div>
{% endfor %}
</div>

<!-- =============================
PRODUCT HEADER
============================= -->
<div>
    <p class="section-subtitle">{{ collections.all.products_count }} Systems Available</p>
    <h1 class="section-title">Systems</h1>
</div>

<!-- FILTER BUTTONS -->
<div class="filter-container">
  <button class="filter-btn active" data-category="all">All</button>
  {% for collection in collections %}
    <button class="filter-btn" data-category="{{ collection.handle }}">
      {{ collection.title }}
    </button>
  {% endfor %}
</div>

<!-- =============================
PRODUCTS
============================= -->
<div class="cards-container">
{% for product in collections.all.products %}
  <div class="product-card"
       data-category="{% for c in product.collections %}{{ c.handle }}{% unless forloop.last %},{% endunless %}{% endfor %}">
    
    <div class="image-wrapper">
        <img src="{{ product.featured_image | img_url: '600x600' }}" class="card-image">

        <!-- HEART -->
        <div class="heart-icon-top" onclick="toggleHeart(this)">
            <i class="fas fa-heart"></i>
        </div>
    </div>

    <div class="card-content">
        <h4>{{ product.title }}</h4>

        <!-- VIEW SYSTEM -->
        <a href="{{ product.url }}" class="view-link">VIEW SYSTEM</a>

        <!-- WISHLIST -->
        <button class="wishlist-btn" onclick="toggleWishlist(this)">
            <i class="fas fa-bookmark"></i>
            <span>Wishlist</span>
        </button>
    </div>

  </div>
{% endfor %}
</div>

<!-- =============================
SCRIPT
============================= -->
<script>
const filterButtons = document.querySelectorAll('.filter-btn');
const productCards = document.querySelectorAll('.product-card');
const collectionCards = document.querySelectorAll('.collection-card');

function activateFilter(category) {

    filterButtons.forEach(btn => btn.classList.remove('active'));
    const activeBtn = document.querySelector(`.filter-btn[data-category="${category}"]`);
    if(activeBtn) activeBtn.classList.add('active');

    productCards.forEach(card => {
        const categories = card.dataset.category.split(',');

        if(category === 'all' || categories.includes(category)) {
            card.style.display = 'block';
        } else {
            card.style.display = 'none';
        }
    });
}

/* BUTTON CLICK */
filterButtons.forEach(btn => {
    btn.addEventListener('click', (e) => {
        e.preventDefault();
        activateFilter(btn.dataset.category);
    });
});

/* COLLECTION CLICK */
collectionCards.forEach(card => {
    card.addEventListener('click', () => {
        activateFilter(card.dataset.category);
    });
});

/* HEART */
function toggleHeart(el){
    el.classList.toggle('active');
}

/* WISHLIST */
function toggleWishlist(el){
    el.classList.toggle('active');
    const text = el.querySelector('span');
    text.textContent = el.classList.contains('active') ? 'Saved' : 'Wishlist';
}

/* DEFAULT */
activateFilter('all');
</script>

{% schema %}
{
  "name": "Final System Filter",
  "settings": [],
  "presets": [{"name": "Final System Filter"}]
}
{% endschema %}