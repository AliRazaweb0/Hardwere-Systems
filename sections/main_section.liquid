<style>
/* ============================================
   TUMHARA CSS - FIRST FULL WIDTH, REST 2 PER ROW
   ============================================ */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: Arial, sans-serif;
}

body {
    background: #f5f5f5;
}

.header {
    padding: 40px 40px 0 40px;
}

.header .subtitle {
    font-size: 11px;
    letter-spacing: 3px;
    color: #888;
    margin-bottom: 8px;
    text-transform: uppercase;
}

.header h1 {
    font-size: 30px;
    color: #222;
    font-weight: bold;
}

/* ============================================
   MAIN CONTAINER - 2 COLUMN GRID BASE
   ============================================ */
.main-container {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    padding: 40px;
}

/* ============================================
   FIRST COLLECTION - FULL WIDTH (SPAN 2)
   ============================================ */
.main-container > div:first-child {
    grid-column: span 2;
    height: 450px;
    position: relative;
    border-radius: 10px;
    overflow: hidden;
    color: #fff;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    transition: transform 0.4s ease;
}

/* ============================================
   BAQI SAB COLLECTIONS - 2 PER ROW (SPAN 1)
   ============================================ */
.main-container > div:not(:first-child) {
    grid-column: span 1;
    height: 275px;
    position: relative;
    border-radius: 10px;
    overflow: hidden;
    color: #fff;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    transition: transform 0.4s ease;
}

/* Gradient overlay - sab cards pe same */
.main-container > div::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.4) 50%, transparent 100%);
    z-index: 1;
}

/* Text styling - sab cards pe same */
.text {
    position: absolute;
    bottom: 25px;
    left: 25px;
    z-index: 2;
    max-width: 80%;
}

.text h3 {
    font-size: 22px;
    font-weight: bold;
    margin-bottom: 8px;
    line-height: 1.2;
}

.text p {
    font-size: 14px;
    opacity: 0.9;
    line-height: 1.4;
    margin-bottom: 5px;
}

.text span {
    display: inline-block;
    margin-top: 10px;
    font-size: 13px;
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 1px;
}

/* Hover effect - sab pe same */
.main-container > div:hover {
    transform: scale(1.04);
    cursor: pointer;
}

/* Link styling - pura card clickable */
.main-container > div > a {
    position: absolute;
    inset: 0;
    z-index: 3;
    text-decoration: none;
    color: inherit;
}

/* ============================================
   RESPONSIVE - TABLET (SAME LAYOUT)
   ============================================ */
@media (max-width: 1024px) {
    .main-container {
        gap: 15px;
        padding: 30px;
    }

    .main-container > div:first-child {
        height: 350px;
    }

    .main-container > div:not(:first-child) {
        height: 220px;
    }
}

/* ============================================
   RESPONSIVE - MOBILE (1 COLUMN)
   ============================================ */
@media (max-width: 768px) {
    .main-container {
        grid-template-columns: 1fr;
        padding: 20px;
        gap: 15px;
    }

    .main-container > div:first-child {
        grid-column: span 1;
        height: 300px;
    }

    .main-container > div:not(:first-child) {
        grid-column: span 1;
        height: 250px;
    }

    .header {
        padding: 20px 20px 0 20px;
    }

    .header h1 {
        font-size: 24px;
    }
}
</style>

<!-- ============================================
     HEADER SECTION
     ============================================ -->
<div class="header">
    <p class="subtitle">{{ section.settings.subtitle | default: "BROWSE BY CATEGORY" }}</p>
    <h1>{{ section.settings.title | default: "System Categories" }}</h1>
</div>

<!-- ============================================
     MAIN CONTAINER - UNLIMITED COLLECTIONS
     ============================================ -->
<div class="main-container">

    {% if collections.size > 0 %}
        {% for collection in collections %}
            {% assign index = forloop.index %}

            <div class="collection-card collection-{{ index }}" 
                 data-category="{{ collection.title }}"
                 style="background-image: url('{{ collection.image | image_url: width: 1200 }}');"
                 {{ block.shopify_attributes }}>

                <a href="{{ collection.url }}">
                    <div class="text">
                        <h3>{{ collection.title | escape }}</h3>
                        {% if collection.description != blank %}
                            <p>{{ collection.description | strip_html | truncate: 100 }}</p>
                        {% endif %}
                        <span>EXPLORE SYSTEMS →</span>
                    </div>
                </a>
            </div>

        {% endfor %}
    {% else %}
        <!-- Default placeholder if no collections exist -->
        <div class="collection-card" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
            <div class="text">
                <h3>No Collections Found</h3>
                <p>Please create collections in your Shopify admin</p>
                <span>GO TO PRODUCTS → COLLECTIONS</span>
            </div>
        </div>
    {% endif %}

</div>

<!-- Filter Script -->
<script>
const filterButtons = document.querySelectorAll('.filter-btn');
const collectionCards = document.querySelectorAll('.collection-card');

filterButtons.forEach(button => {
    button.addEventListener('click', (e) => {
        e.preventDefault(); // ✅ Prevent page reload

        // Remove active class from all buttons
        filterButtons.forEach(btn => btn.classList.remove('active'));
        button.classList.add('active');

        const category = button.dataset.category;

        collectionCards.forEach(card => {
            if(category === 'all') {
                card.style.display = 'block';
            } else {
                if(card.dataset.category === category){
                    card.style.display = 'block';
                } else {
                    card.style.display = 'none';
                }
            }
        });
    });
});
</script>
{% schema %}
{
  "name": "System Categories",
  "tag": "section",
  "class": "system-categories-section",
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "BROWSE BY CATEGORY"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "System Categories"
    }
  ],
  "presets": [
    {
      "name": "System Categories",
      "settings": {
        "subtitle": "BROWSE BY CATEGORY",
        "title": "System Categories"
      }
    }
  ]
}
{% endschema %}