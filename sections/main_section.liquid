<style>
/* TUMHARA CSS BILKUL SAME */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: Arial, sans-serif;
}

body {
    background: #f5f5f5;
}

.header {
    padding: 40px 40px 0 40px;
}

.header .subtitle {
    font-size: 11px;
    letter-spacing: 3px;
    color: #888;
    margin-bottom: 8px;
}

.header h1 {
    font-size: 30px;
    color: #222;
}

.main-container {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-template-rows: repeat(2, 180px) repeat(2, 275px);
    gap: 20px;
    padding: 40px;
}

.main-container > div {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 10px;
    overflow: hidden;
    color: #fff;
    background-size: cover;
    background-position: center;
}

.pic1 {
    grid-column: span 2;
    grid-row: span 2;
}

.main-container > div::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
    z-index: 1;
}

.text {
    position: absolute;
    bottom: 25px;
    left: 25px;
    z-index: 2;
    max-width: 80%;
}

.text h3 {
    font-size: 22px;
    font-weight: bold;
    margin-bottom: 8px;
}

.text p {
    font-size: 14px;
    opacity: 0.9;
}

.text span {
    display: inline-block;
    margin-top: 10px;
    font-size: 13px;
    font-weight: bold;
}

.main-container > div:hover {
    transform: scale(1.04);
    transition: 0.4s;
    cursor: pointer;
}
</style>

<div class="header">
    <p class="subtitle">BROWSE BY CATEGORY</p>
    <h1>System Categories</h1>
</div>

<div class="main-container">

    <div class="main-container">

{% assign col_links = linklists['homepage-collections'].links %}

{% for link in col_links %}
  {% assign collection = link.object %}

  <div class="pic{{ forloop.index }}" 
       style="background-image: url({{ collection.image | image_url }})">

    <a href="{{ collection.url }}">
      <div class="text">
        <h3>{{ collection.title }}</h3>
        <p>{{ collection.description | strip_html | truncate: 120 }}</p>
        <span>EXPLORE SYSTEMS →</span>
      </div>
    </a>

  </div>

{% endfor %}

</div>

</div>

{% schema %}
{
  "name": "Mainsection",
  "settings": [],
  "blocks": [
    {
      "type": "collection_block",
      "name": "Collection",
      "settings": [
      ]
    }
  ],
  "presets": [
    {
      "name": "Mainsection",
    }
  ]
}
{% endschema %}