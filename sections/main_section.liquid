<!-- FONT AWESOME -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
body {
    font-family: Arial, sans-serif;
    background: #f8f8f8;
    padding:20px
}

/* ===== HEADINGS ===== */
.section-subtitle {
    margin-top: 12px;
    margin-bottom: 0; /* remove bottom space */
    font-size: 12px;
}
/* Systems Heading */
.section-title {
    font-size: 30px; /* thoda balanced */
}

/* ===== COLLECTION HEADER ===== */
.collection-header {
    margin-top: 100px;
    margin-bottom:50px
}

.collection-subtitle {
    margin-top: 12px;
    margin-bottom: 0; /* remove bottom space */
    font-size: 12px;
}


/* System Categories */
.collection-title {
    font-size: 30px; /* pehle ~30px tha → ab 10px kam */
    margin-top: 0;
    margin-bottom: 0;
}

/* ===== COLLECTION GRID ===== */
.main-container {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-bottom: 30px;
}

.main-container > div:first-child {
    grid-column: span 2;
    height: 400px;
}

.collection-card {
    height: 270px; /* thoda bada card height */
    border-radius: 10px;
    background-size: cover;
    background-position: center;
    position: relative;
    cursor: pointer;
    overflow: hidden;
    transition: transform 0.3s, box-shadow 0.3s;
}

.collection-card:hover {
    transform: scale(1.03);
    box-shadow: 0 8px 20px rgba(0,0,0,0.3);
}

.collection-text {
    position: absolute;
    bottom: 20px;
    left: 20px;
    color: white;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 6px;
}

.collection-title {
    font-size: 22px;
    margin: 0;
}

.collection-description {
    font-size: 16px;
    color:rgba(255, 255, 255, 0.8); /* light shade for description */
    margin: 0;
}

.explore-btn {
    display: inline-block;
    margin-top: 5px;
    padding: 6px 12px;
    color: white;
    border-radius: 6px;
    text-decoration: none;
    font-size: 20px;
    font-weight: 500;
    transition: transform 0.2s, background-color 0.2s;
}

.explore-btn:hover {
    transform: scale(1.05);
    background-color: #333;
}

/* ===== FILTER BUTTON ===== */
.filter-container {
    margin-bottom: 20px;
}

.filter-btn {
    padding: 8px 14px;
    border: 1px solid #ccc;
    cursor: pointer;
    margin-right: 5px;
    background: white;
}

.filter-btn.active {
    background: black;
    color: white;
}

/* ===== PRODUCT CARDS ===== */
.cards-container {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
}

.product-card {
    width: calc(33.33% - 14px);
    background: white;
    border-radius: 10px;
    overflow: hidden;
}
.product-card {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.product-card:hover {
    transform: translateY(-8px); /* thoda upar uthna */
    box-shadow: 0 12px 25px rgba(0,0,0,0.2); /* subtle shadow */
}
.image-wrapper {
    position: relative;
}

.card-image {
    width: 100%;
    height: 270px;
    object-fit: cover;
}

/* HEART ICON */
.heart-icon-top {
    position: absolute;
    top: 10px;
    right: 10px;
    background: white;
    padding: 8px;
    border-radius: 50%;
    cursor: pointer;
}

.heart-icon-top.active {
    color: red;
}

/* CONTENT */
.card-content {
    padding: 15px;
}

.view-link {
    display: inline-block;
    margin-top: 10px; /* space above wishlist */
    color: black;
    text-decoration: none;
    
}
.view-link:hover{
color:blue
}

.wishlisting .wishlist-btn {
    margin-top: 8px; 
    padding: 8px;
    border: none;
    background: #eee;
    cursor: pointer;
    border-radius: 6px;
    transition: transform 0.2s ease, background 0.2s ease; /* smooth zoom */
}

.wishlisting .wishlist-btn:hover {
    transform: scale(1.2); /* zoom in on hover */
    background: #ddd; /* optional subtle color change */
}

.wishlisting .wishlist-btn.active {
    background: red;
    color: white;
}

.wishlisting .wishlist-btn.active:hover {
    transform: scale(1.2);
    background: #c0392b; /* darker red when active hover */
}
.section-header {
    margin-top: 100px;
    margin-bottom: 50px;
}
</style>

<!-- =============================
COLLECTION HEADER
============================= -->


<!-- =============================
COLLECTION CARDS
============================= -->
<!-- COLLECTION CARDS -->
<div class="main-container">
{% for collection in collections %}
  <div class="collection-card"
       data-category="{{ collection.handle }}"
       style="background-image:url('{{ collection.image | image_url: width: 1000 }}')">

    <div class="collection-text">
      <!-- COLLECTION TITLE -->
      <h3 class="collection-title">{{ collection.title }}</h3>

      <!-- COLLECTION DESCRIPTION -->
      <p class="collection-description">
        Precision-engineered shower screen hardware and enclosure systems for modern bathrooms.
      </p>

      <!-- EXPLORE BUTTON -->
      <a href="{{ collection.url }}" class="explore-btn">Explore Systems</a>
    </div>
  </div>
{% endfor %}
</div>

<!-- =============================
// PRODUCT HEADER
============================= -->
<div class="section-header">
    <p class="section-subtitle" id="product-count">{{ collections.all.products_count }} Systems Available</p>
    <h1 class="section-title">Systems</h1>
</div>

<!-- FILTER BUTTONS -->
<div class="filter-container">
  <button class="filter-btn active" data-category="all">All</button>
  {% for collection in collections %}
    <button class="filter-btn" data-category="{{ collection.handle }}">
      {{ collection.title }}
    </button>
  {% endfor %}
</div>

<!-- PRODUCTS -->
<div class="cards-container">
{% for product in collections.all.products %}
  <div class="product-card"
       data-category="{% for c in product.collections %}{{ c.handle }}{% unless forloop.last %},{% endunless %}{% endfor %}">
    
    <div class="image-wrapper">
        <img src="{{ product.featured_image | img_url: '600x600' }}" class="card-image">
        <div class="heart-icon-top" onclick="toggleHeart(this)">
            <i class="fas fa-heart"></i>
        </div>
    </div>

    <div class="card-content">
        <h4>{{ product.title }}</h4>
        <a href="{{ product.url }}" class="view-link">VIEW SYSTEM</a>

        <button class="wishlist-btn" onclick="toggleWishlist(this)">
            <i class="fas fa-bookmark"></i>
            <span>Wishlist</span>
        </button>
    </div>

  </div>
{% endfor %}
</div>


<script>
// Get references
const filterButtons = document.querySelectorAll('.filter-btn');
const productCards = document.querySelectorAll('.product-card');
const productCount = document.getElementById('product-count');
const collectionCards = document.querySelectorAll('.collection-card');
const productSection = document.querySelector('.section-header'); // Product section (All Systems)

// Function to filter products and update count
function activateFilter(category){
    // Remove active class from buttons
    filterButtons.forEach(btn => btn.classList.remove('active'));

    // Add active class to current button
    const activeBtn = document.querySelector(`.filter-btn[data-category="${category}"]`);
    if(activeBtn) activeBtn.classList.add('active');

    // Show/Hide products and count
    let count = 0;
    productCards.forEach(card => {
        const categories = card.dataset.category.split(',');
        if(category === 'all' || categories.includes(category)){
            card.style.display = 'block';
            count++;
        } else {
            card.style.display = 'none';
        }
    });

    // Update count
    productCount.textContent = `${count} Systems Available`;
}

// Smooth scroll to product section
function scrollToProducts() {
    productSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

// Button click filtering
filterButtons.forEach(btn => {
    btn.addEventListener('click', (e) => {
        e.preventDefault();
        activateFilter(btn.dataset.category);
        scrollToProducts();
    });
});

// Collection card click filtering + scroll
collectionCards.forEach(card => {
    card.addEventListener('click', () => {
        activateFilter(card.dataset.category);
        scrollToProducts();
    });
});

// Heart toggle
function toggleHeart(el){
    el.classList.toggle('active');
}

// Wishlist toggle
function toggleWishlist(el){
    el.classList.toggle('active');
    const text = el.querySelector('span');
    text.textContent = el.classList.contains('active') ? 'Saved' : 'Wishlist';
}

// Default: show all products
activateFilter('all');
</script>{% schema %}
