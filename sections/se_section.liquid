<style>
{% comment %} .para{
color:red;
margin-top: 20px; 
margin-left:30px;
}, {% endcomment %}
h1{
   
padding-top:{{ section.settings.padding_top }}rem;
},
h1{
font-size:{{ section.settings.font_size }}px;
}

</style>
<div class="header">

<h1>{{ section.settings.heading_text }}</h1>




</div>
<div class="para">

<p> {{ section.settings.paragraph }}</p>
 {%if section.settings.padding_top > 0 %}
{{ section.settings.mynum }}
 {% endif %}
</div>




{% schema %}
{
"name": "Heading",
"settings": [
    {
    "type": "text",
"id": "heading_text",
"label": "Heading"
},
{
"type": "textarea",
"id": "paragraph",
"label": "Write Paragraph",
"default":"Write your brand paragraph",
},
{
"type": "number",
"id": "mynum",
"label": "My Number",
"default":786
},
{
"type": "range",
"id": "padding_top",
"label": "Padding Top",
"step": 1,
"unit": "rem",
"min": 1,
"max": 100,
"default":2,

},
{
"type": "range",
"id": "font_size",
"label": "Heading Font Size",
"max": 100,
"min": 1,
"unit": "px",
"default":15,
"step": 1,




}
],
"blocks": [],
"presets": [
    {
    "name": "Class 1"
    }
]


}




{% endschema %}





